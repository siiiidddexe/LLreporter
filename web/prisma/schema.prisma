// LLReporter schema — SQLite (embedded, zero-setup)
// Single file lives at /app/web/data/llreporter.db inside the container.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite on Prisma has no native enums — roles/statuses are validated at the API layer.
// Valid role values:   "SUPER_ADMIN" | "MEMBER"
// Valid status values: "OPEN" | "IN_PROGRESS" | "NEEDS_TESTING" | "RESOLVED" | "UNRESOLVED" | "CLOSED"

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          String    @default("MEMBER")
  // Bumping this invalidates every outstanding JWT → "force sign out"
  tokenVersion  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships   Membership[]
  reportedBugs  Bug[]        @relation("reporter")
  assignedBugs  Bug[]        @relation("assignee")
  comments      Comment[]
}

model Project {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  apiKey      String       @unique // "llr_live_xxx"
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  memberships Membership[]
  bugSets     BugSet[]
  bugs        Bug[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

/// A "bug set" = all reports against the same canonical URL within a project.
model BugSet {
  id         String   @id @default(cuid())
  projectId  String
  url        String   // canonicalized origin + path
  title      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bugs       Bug[]

  @@unique([projectId, url])
  @@index([projectId])
}

model Bug {
  id           String    @id @default(cuid())
  projectId    String
  bugSetId     String
  reporterId   String
  assigneeId   String?
  url          String
  title        String
  description  String
  screenshot   String?   // path under /uploads (e.g. /uploads/abc.png)
  userAgent    String?
  status       String    @default("OPEN")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bugSet    BugSet    @relation(fields: [bugSetId], references: [id], onDelete: Cascade)
  reporter  User      @relation("reporter", fields: [reporterId], references: [id])
  assignee  User?     @relation("assignee", fields: [assigneeId], references: [id])
  comments  Comment[]

  @@index([projectId, status])
  @@index([bugSetId])
}

model Comment {
  id        String   @id @default(cuid())
  bugId     String
  authorId  String
  // "human" or "claude" — lets the UI badge AI patches differently
  kind      String   @default("human")
  body      String
  createdAt DateTime @default(now())

  bug    Bug  @relation(fields: [bugId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([bugId])
}
