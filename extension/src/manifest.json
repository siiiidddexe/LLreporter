{
  "manifest_version": 3,
  "name": "LLReporter — LogicLaunch Bug Capture",
  "version": "0.1.0",
  "description": "Press ⌘K / Ctrl+K on any page to report a bug. Pastes screenshots, auto-captures URL, sends to webaudit.logiclaunch.in.",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["https://webaudit.logiclaunch.in/*", "http://localhost:3000/*", "<all_urls>"],
  "action": { "default_popup": "popup.html", "default_title": "LLReporter" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["modal.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "commands": {
    "open-reporter": {
      "suggested_key": {
        "default": "Ctrl+K",
        "mac": "Command+K"
      },
      "description": "Open the LLReporter modal"
    }
  },
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" },
  "web_accessible_resources": [
    { "resources": ["modal.css"], "matches": ["<all_urls>"] }
  ]
}
