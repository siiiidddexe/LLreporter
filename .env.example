# LLReporter env — EVERYTHING IS OPTIONAL. Defaults are baked into docker-compose.yml.
# Only override NEXTAUTH_SECRET in production.

# Auth signing key. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=llreporter-default-secret-please-override-in-production-aZbYcXdWeVfUgThSiRjQkPlOmN

# Public URL of the dashboard (used by the Chrome extension + connector)
PUBLIC_URL=https://webaudit.logiclaunch.in

# First-boot super-admin (seeded only if no admin exists; idempotent)
SEED_ADMIN_EMAIL=admin@logiclaunch.in
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_NAME=Super Admin

# Embedded SQLite path — leave as-is
DATABASE_URL=file:/app/web/data/llreporter.db
